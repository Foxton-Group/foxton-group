---
import HeritageCarousel from './HeritageCarousel.astro';

interface Props {
  carouselId: string;
  images: any[];
  title: string;
  subtitle: string;
  description: string;
  pdfUrl?: string;
  reverse?: true;        // set to true to swap carousel ↔ text
}

const { carouselId, images, title, subtitle, description, pdfUrl, reverse = false } = Astro.props;
---

<div class={`mission-grid ${reverse ? 'mission-grid--reverse' : ''}`}>
  <!-- Carousel side -->
  <div class="main-image-container">
    <HeritageCarousel images={images} carouselId={carouselId} />
  </div>

  <!-- Text side -->
  <div class="text-content">
    <h3>{title}</h3>
    <p class="mission-subtitle">{subtitle}</p>
    <p>{description}</p>

    {pdfUrl && (
      <div class="remediation-plan mt-8 text-center">
        <a 
          href={pdfUrl}
          target="_blank"
          class="inline-flex items-center gap-x-3 bg-[#0A3D2F] hover:bg-[#0A3D2F]/90 text-white font-medium text-lg px-8 py-4 rounded-2xl transition-colors shadow-sm"
        >
          📄 See our full dry rot remediation plan here
        </a>
      </div>
    )}
  </div>
</div>

<style>
/* Clean centered container - same pattern as Contact/Projects */
.mission-grid,
.mission-grid--reverse {
  display: grid;
  gap: 1rem;
  margin-bottom: 4rem;
  align-items: start;
  max-width: 1480px;           /* ← this keeps it balanced on massive screens */
  margin-left: auto;
  margin-right: auto;
  width: 100% !important;
  padding: 0 2rem;
}

/* Normal layout - image on left */
.mission-grid {
  grid-template-columns: 33.6vw 13vw 1fr;
}

/* Reverse layout - image on right */
.mission-grid--reverse {
  grid-template-columns: 1fr 13vw 33.6vw;
}

/* Children positioning */
.main-image-container {
  grid-column: 1;
  align-self: start;
}
.mission-grid--reverse .main-image-container {
  grid-column: 3;
  align-self: start;
}

.text-content {
  grid-column: 3;
  padding-top: 0.15rem;
  padding-left: 0;
  padding-right: 2rem;
  align-self: stretch;
}
.mission-grid--reverse .text-content {
  grid-column: 1;
  padding-top: 0.15rem;
  padding-left: 2rem;
  padding-right: 0;
  align-self: stretch;
}

/* Text styling (unchanged) */
.text-content h3 {
  font-size: 1.8rem;
  font-weight: 600;
  color: #0A3D2F;
  margin-bottom: 0.5rem;
  text-transform: uppercase;
  letter-spacing: 1px;
  text-align: center;
}
.mission-grid--reverse .text-content h3 {
  text-align: left;
}

.mission-subtitle {
  font-size: 1.55rem;
  font-weight: 500;
  color: #666;
  margin-bottom: 1rem;
  text-align: center;
}
.mission-grid--reverse .mission-subtitle {
  text-align: left;
}

.text-content p {
  font-size: 0.85rem;
  line-height: 1.4;
  color: #333;
}

/* Mobile stacking - image first, then text */
@media (max-width: 1024px) {
  .mission-grid,
  .mission-grid--reverse {
    grid-template-columns: 1fr;
    gap: 2rem;
    padding: 0 1rem;
  }
  .main-image-container,
  .text-content,
  .mission-grid--reverse .main-image-container,
  .mission-grid--reverse .text-content {
    grid-column: 1;
  }
  .text-content {
    padding-top: 0;
    padding-left: 0;
    padding-right: 0;
  }
}

/* Force both children onto the same row (safety for reverse) */
.main-image-container,
.text-content,
.mission-grid--reverse .main-image-container,
.mission-grid--reverse .text-content {
  grid-row: 1;
}
</style>