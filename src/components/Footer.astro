---
import { Image } from 'astro:assets';
import footerImage from '../assets/images/Peel Street/Peel Street Main Bathroom.jpeg';
---

<footer class="site-footer">
  <div class="footer-grid">
    <!-- LEFT: All text content -->
    <div class="footer-content">
      <h2>Discuss your next project</h2>

      <div class="text-columns">
        <!-- Company block -->
        <div class="company-info">
          <strong>Foxton Group Ltd</strong>
          <p>St Ives,<br>Cornwall, TR26 3HW</p>
        </div>

        <!-- Contact block -->
        <div class="contact-info">
          <p><strong>Office</strong> 01736 595 568</p>
          <p>Email: <a href="mailto:dan@foxton-group.com">dan@foxton-group.com</a></p>
          <p>Vendors: <a href="mailto:accounts@foxton-group.com">accounts@foxton-group.com</a></p>
        </div>
      </div>

      <div class="social-icons">
        <a href="#" target="_blank" aria-label="Instagram">
          <svg xmlns="http://www.w3.org/2000/svg" width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round" stroke-linecap="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
        <a href="#" target="_blank" aria-label="Facebook">
          <svg xmlns="http://www.w3.org/2000/svg" width="52" height="52" viewBox="0 0 24 24" fill="#1877F2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
        <a href="#" target="_blank" aria-label="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" width="52" height="52" viewBox="0 0 24 24" fill="#0A66C2"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/><path d="M8 9h2v8H8z"/><circle cx="12" cy="7" r="2"/></svg>
        </a>
      </div>

      <div class="privacy">
        <a href="/privacy-policy">Please click here for our Privacy Policy.</a>
      </div>

      <div class="copyright">
        All content © Copyright 2026 Foxton Group Ltd and protected under UK and International law.<br>
        Duplication, reproduction and/or distribution of any material on this website is strictly prohibited.<br>
        All rights reserved.
      </div>
    </div>

    <!-- RIGHT: Image -->
    <div class="footer-image-wrapper">
      <Image 
        src={footerImage} 
        alt="Peel Street Main Bathroom" 
        class="footer-image"
        loading="lazy"
      />
    </div>
  </div>
</footer>

<style>
.site-footer {
  background: #fff;
  padding: 5rem 0 3rem;
}

.footer-grid {
  max-width: 1480px;
  margin-left: auto;
  margin-right: auto;
  padding: 0 2rem;
  display: grid;
  grid-template-columns: 1fr 520px;
  gap: 5rem;
  align-items: start;
}

/* Text side */
.footer-content h2 {
  font-size: 2.35rem;
  line-height: 1.15;
  font-weight: 600;
  color: #0A3D2F;
  margin-bottom: 1.75rem;
}

.text-columns {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  margin-bottom: 2.5rem;
}

.company-info strong {
  font-size: 1.35rem;
  color: #0A3D2F;
  display: block;
  padding-top: 0.8vh;
  margin-bottom: 0.5rem;
}

.company-info p,
.contact-info p {
  font-size: 1.1rem;
  line-height: 1.45;
  color: #333;
  margin-bottom: 0.75rem;
}

.contact-info a {
  color: #0A3D2F;
  text-decoration: none;
}

.contact-info a:hover {
  text-decoration: underline;
}

.social-icons {
  display: flex;
  gap: 1.25rem;
  margin-bottom: 2.5rem;
}

.social-icons a {
  display: block;
  width: 52px;
  height: 52px;
}

.social-icons svg {
  width: 52px;
  height: 52px;
  transition: transform 0.3s ease;
}

.social-icons a:hover svg {
  transform: scale(1.1);
}

.privacy a {
  color: #0A3D2F;
  text-decoration: none;
  font-size: 1.05rem;
}

.privacy a:hover {
  text-decoration: underline;
}

.copyright {
  font-size: 0.85rem;
  line-height: 1.45;
  color: #555;
  max-width: 80%;
}

/* Image side */
.footer-image-wrapper {
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 15px 35px rgba(0,0,0,0.12);
}

.footer-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* ===================== MOBILE ===================== */
@media (max-width: 1024px) {
  .footer-grid {
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  
  .text-columns {
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  
  .footer-content h2 {
    font-size: 2rem;
  }
}
</style>