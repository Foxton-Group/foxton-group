---
interface Props {
  title: string;
  description: string;
  images: string[];
}
const { title, description, images = [] } = Astro.props;
const mainImage = images[0] || '';
const thumbnails = images.slice(1);
---

<div class="work-category">
  <div class="main-image-container">
    <img 
      src={mainImage} 
      alt={title} 
      data-cat={title} 
      data-idx="0" 
      class="featured-image" 
    />
  </div>
  <div class="thumbnail-stack">
    {thumbnails.map((src, idx) => (
      <img 
        src={src} 
        alt={`${title} thumbnail ${idx + 1}`} 
        data-cat={title} 
        data-idx={idx + 1} 
        class="thumbnail" 
      />
    ))}
  </div>
  <div class="text-content">
    <h3>{title}</h3>
    <p>{description}</p>
  </div>
</div>

<style>
.work-category {
  display: grid;
  grid-template-columns: 28vw 13vw 1fr;
  gap: 1rem;
  margin-bottom: 4rem;
  align-items: start;
  width: 100%;
}

/* Desktop columns */
.main-image-container { grid-column: 1; }
.thumbnail-stack     { grid-column: 2; }
.text-content        { grid-column: 3; }

/* Thumbnails */
.thumbnail-stack {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.featured-image, .thumbnail {
  width: 100%;
  aspect-ratio: 16 / 10;
  object-fit: cover;
  border-radius: 12px;
  cursor: pointer;
}

.thumbnail {
  aspect-ratio: 4 / 3;
  max-width: 2.2vw;
}

/* Text */
.text-content {
  padding-top: 0.15rem;
  padding-right: 2rem;
}

.text-content h3 {
  font-size: 1.1rem;
  font-weight: 600;
  color: #0A3D2F;
  margin-bottom: 0.5rem;
  text-transform: uppercase;
  letter-spacing: 1px;
  text-align: center;
}

.text-content p {
  font-size: 0.85rem;
  line-height: 1.4;
  color: #333;
}

/* ──────── MOBILE STACKING ──────── */
@media (max-width: 1024px) {
  .work-category {
    grid-template-columns: 1fr;        /* single column */
    gap: 2rem;
  }

  .main-image-container,
  .thumbnail-stack,
  .text-content {
    grid-column: 1;                    /* all stack in source order */
  }

  .thumbnail-stack {
    flex-direction: row;               /* thumbnails side-by-side on mobile */
    justify-content: center;
    gap: 0.8rem;
  }

  .thumbnail {
    max-width: 22vw;                   /* bigger and nicer on mobile */
  }

  .text-content {
    padding-top: 0;
    padding-right: 0;
    text-align: center;                /* cleaner on mobile */
  }

  .text-content h3 {
    text-align: center;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  // Attach click listeners to all thumbnails in this component
  const images = document.querySelectorAll('.work-category img[data-cat]');
  images.forEach(img => {
    img.addEventListener('click', () => {
      const cat = img.getAttribute('data-cat');
      const idx = parseInt(img.getAttribute('data-idx') || '0');
      console.log('🔥 Thumbnail clicked → Category:', cat, 'Index:', idx);
      if (typeof window.openLightbox === 'function') {
        window.openLightbox(cat, idx);
      } else {
        console.error('window.openLightbox function not found');
      }
    });
  });
});
</script>