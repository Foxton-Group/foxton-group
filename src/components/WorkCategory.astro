---
interface Props {
  title: string;
  description: string;
  images: string[];
}
const { title, description, images = [] } = Astro.props;
const mainImage = images[0] || '';
const thumbnails = images.slice(1);
---

<div class="work-category">
  <div class="main-image-container">
    <img 
      src={mainImage} 
      alt={title} 
      data-cat={title} 
      data-idx="0" 
      class="featured-image" 
    />
  </div>
  <div class="thumbnail-stack">
    {thumbnails.map((src, idx) => (
      <img 
        src={src} 
        alt={`${title} thumbnail ${idx + 1}`} 
        data-cat={title} 
        data-idx={idx + 1} 
        class="thumbnail" 
      />
    ))}
  </div>
  <div class="text-content">
    <h3>{title}</h3>
    <p>{description}</p>
  </div>
</div>

<style>
/* ===================== WORK CATEGORY COMPONENT ===================== */
.work-category {
  display: grid;
  grid-template-columns: 460px 95px 1fr;
  gap: 1.5rem;
  margin-bottom: 4.5rem;
  align-items: start;
  width: 100%;
  max-width: 1480px;
  margin-left: auto;
  margin-right: auto;
}

/* Desktop column positions */
.main-image-container { grid-column: 1; }
.thumbnail-stack { grid-column: 2; }
.text-content { grid-column: 3; }

/* Images */
.featured-image,
.thumbnail {
  width: 100%;
  aspect-ratio: 5 / 4;           /* ← changed from 16/10 */
  object-fit: cover;
  border-radius: 12px;
  cursor: pointer;
}

.thumbnail-stack {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
  align-self: center;
}

.thumbnail {
  aspect-ratio: 4 / 3;           /* thumbnails also 4/3 now for consistency */
  max-width: 95px;
}

/* Text */
.text-content {
  padding-top: 0.25rem;
  padding-right: 1.25rem;
}

.text-content h3 {
  font-size: 1.15rem;
  font-weight: 600;
  color: #0A3D2F;
  margin-bottom: 0.6rem;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.text-content p {
  font-size: 0.95rem;
  line-height: 1.55;
  color: #333;
}

//* Mobile - simple, balanced, main image prominent */
@media (max-width: 1024px) {
  .work-category {
    grid-template-columns: 1fr;
    gap: 1.5rem;
    max-width: none;
    padding: 0 1rem;
  }

  .thumbnail-stack {
    display: none;   /* hide thumbnails completely on mobile */
  }

  .featured-image {
    width: 100%;
    aspect-ratio: 16 / 10;
    border-radius: 12px;
  }

  .text-content {
    padding-top: 0;
    padding-right: 0;
    text-align: center;   /* centres the text properly */
  }
}

/* Extra large screens */
@media (min-width: 1800px) {
  .work-category { max-width: 1600px; }
}
</style>


<script>
document.addEventListener('DOMContentLoaded', () => {
  // Attach click listeners to all thumbnails in this component
  const images = document.querySelectorAll('.work-category img[data-cat]');
  images.forEach(img => {
    img.addEventListener('click', () => {
      const cat = img.getAttribute('data-cat');
      const idx = parseInt(img.getAttribute('data-idx') || '0');
      console.log('🔥 Thumbnail clicked → Category:', cat, 'Index:', idx);
      if (typeof window.openLightbox === 'function') {
        window.openLightbox(cat, idx);
      } else {
        console.error('window.openLightbox function not found');
      }
    });
  });
});
</script>