---
interface Props {
  title: string;
  description: string;
  images: string[];
}

const { title, description, images = [] } = Astro.props;
---

<div class="work-category">
  <div class="image-grid">
    {images.map((src, i) => (
      <img
        src={src}
        alt={`${title} project ${i + 1}`}
        data-cat={title}
        data-idx={i}
        loading="eager"          /* ← forces fast loading */
        decoding="async"         /* ← extra speed boost */
      />
    ))}
  </div>

  <div class="text-content">
    <h3>{title}</h3>
    <p>{description}</p>
  </div>
</div>

<style>
  .work-category {
    display: flex;
    gap: 3rem;
    align-items: flex-start;
    margin-bottom: 4rem;
    width: 100%;
  }

  .image-grid {
    flex: 1.85;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  .image-grid img {
    width: 100%;
    aspect-ratio: 1.65 / 1;
    object-fit: cover;
    border-radius: 0.75rem;
    cursor: pointer;
    transition: transform 0.2s ease;
  }

  .image-grid img:hover {
    transform: scale(1.03);
  }

  .text-content {
    flex: 1;
    padding-top: 0.1rem;
  }

  .text-content h3 {
    font-size: clamp(1.75rem, 3vw, 2.375rem);
    font-weight: 600;
    color: #0A3D2F;
    margin-bottom: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.03125rem;
  }

  .text-content p {
    font-size: clamp(1.05rem, 1.75vw, 1.25rem);
    line-height: 1.6;
    color: #333;
  }

  @media (max-width: 1024px) {
    .work-category { flex-direction: column; gap: 2rem; }
    .image-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 640px) {
    .image-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>