---
import { Image } from 'astro:assets';
import diningImg from '../assets/images/Peel Street Dining.jpeg';
import hallImg from '../assets/images/Peel Street Hall.jpeg';
import bathroomImg from '../assets/images/Peel Street Main Bathroom.jpeg';
---

<section class="hero-carousel">
  <div class="carousel-wrapper">
    <div class="carousel-inner" id="carousel-inner">
      <div class="slide"><Image src={diningImg} alt="Peel Street Dining" class="hero-image" loading="eager" /></div>
      <div class="slide"><Image src={hallImg} alt="Peel Street Hall" class="hero-image" loading="eager" /></div>
      <div class="slide"><Image src={bathroomImg} alt="Peel Street Main Bathroom" class="hero-image" loading="eager" /></div>
    </div>

    <div class="overlay">
      <div class="overlay-content">
        <h1>Luxury Residential &amp; Commercial<br>Construction without Compromise</h1>
        <a href="/contact" class="cta-button">TALK TO US ABOUT YOUR PROJECT</a>
      </div>
    </div>

    <button id="prev-btn" class="carousel-btn prev-btn" aria-label="Previous slide">‹</button>
    <button id="next-btn" class="carousel-btn next-btn" aria-label="Next slide">›</button>
  </div>
</section>

<style>
  .hero-carousel {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }

  .carousel-wrapper { position: relative; width: 100%; height: 100%; }

  .carousel-inner {
    display: flex;
    height: 100%;
    width: 300%;
    transition: transform 1000ms cubic-bezier(0.32, 0.72, 0, 1);
  }

  .slide { flex: 0 0 100%; width: 100%; height: 100%; position: relative; }

  .hero-image {
    width: calc(100% / 3) !important;
    height: 100% !important;
    object-fit: cover;
    object-position: center 22%;
    display: block;
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.35), rgba(0,0,0,0.15));
    display: flex;
    align-items: flex-end;           /* ← moved to bottom */
    justify-content: center;
    padding-bottom: 4.5rem;          /* ← nice breathing room at bottom */
    z-index: 10;
  }

  .overlay-content {
    text-align: center;
    max-width: 68.75rem;
    padding: 0 2rem;
  }

  .overlay-content h1 {
    font-size: clamp(2.75rem, 5vw, 3.8rem);
    line-height: 1.1;
    font-weight: 300;
    color: white;
    margin-bottom: 1.75rem;
  }

  .cta-button {
    display: inline-block;
    background: white;
    color: #1a1a1a;
    font-size: clamp(1.05rem, 1.8vw, 1.2rem);
    font-weight: 500;
    padding: 1rem 2.75rem;
    border-radius: 9999px;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .cta-button:hover {
    background: rgba(255,255,255,0.95);
    transform: scale(1.05);
  }

  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.95);
    color: #1a1a1a;
    width: 3.875rem;
    height: 3.875rem;
    border: none;
    border-radius: 50%;
    font-size: 2.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 20;
    box-shadow: 0 0.25rem 0.75rem rgba(0,0,0,0.15);
    transition: all 0.3s ease;
  }
  .prev-btn { left: 2rem; }
  .next-btn { right: 2rem; }

  .carousel-btn:hover {
    background: white;
    transform: translateY(-50%) scale(1.1);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const inner = document.getElementById('carousel-inner');
    let current = 0;
    const total = 3;
    function goToSlide(n) {
      current = (n + total) % total;
      inner.style.transform = `translateX(-${current * 100}%)`;
    }
    document.getElementById('prev-btn').addEventListener('click', () => goToSlide(current - 1));
    document.getElementById('next-btn').addEventListener('click', () => goToSlide(current + 1));
  });
</script>