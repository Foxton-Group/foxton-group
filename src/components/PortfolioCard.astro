---
import { Image } from 'astro:assets';
interface Props {
  image: any;
  title: string;
  description: string;
  link: string;
}
const { image, title, description, link } = Astro.props;
---

<div class="portfolio-card">
  <img src={image.src} alt={title} class="portfolio-img" />

  <div class="portfolio-content">
    <h3>{title}</h3>
    <p>{description}</p>
    <a href={link} class="btn-secondary">SEE MORE</a>
  </div>
</div>

<style>
  .portfolio-card {
    background: white;
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: 0 0.625rem 1.875rem rgba(0,0,0,0.08);
    transition: transform 0.3s ease;
    flex: 1 1 420px;
    min-width: 380px;
    max-width: none;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .portfolio-img {
    width: 100%;
    aspect-ratio: 16 / 10.2;
    object-fit: cover;
    object-position: center 30%;
    display: block;
    flex-shrink: 0;
  }

  .portfolio-content {
    padding: 1.75rem 1.75rem 2rem;
    text-align: center;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .portfolio-card h3 {
    font-size: clamp(1.35rem, 2.8vw, 1.95rem);
    margin-bottom: 0.75rem;
    font-weight: 600;
    color: #0A3D2F;
  }

  .portfolio-card p {
    color: #666;
    line-height: 1.55;
    font-size: clamp(0.95rem, 1.6vw, 1.1rem);
    margin-bottom: 1.5rem;
    flex-grow: 1;
  }

  .btn-secondary {
    display: inline-block;
    margin: 0 auto;
    padding: 0.85rem 2.25rem;
    background: #f5f5f5;
    color: #222;
    border-radius: 9999px;
    text-decoration: none;
    font-weight: 500;
    font-size: clamp(0.95rem, 1.4vw, 1.1rem);
    transition: all 0.3s;
  }

  .btn-secondary:hover {
    background: #222;
    color: #fff;
  }
</style>