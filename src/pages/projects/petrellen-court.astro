---
import MainLayout from '../../layouts/MainLayout.astro';

// Explicit imports
import heroImg from '../../assets/images/Slug Herritagae PICs/SlugH1.jpeg';

import SlugH2 from '../../assets/images/Slug Herritagae PICs/SlugH2.jpeg';
import SlugH3 from '../../assets/images/Slug Herritagae PICs/SlugH3.jpeg';
import SlugH4 from '../../assets/images/Slug Herritagae PICs/SlugH4.jpeg';
import SlugH5 from '../../assets/images/Slug Herritagae PICs/SlugH5.jpeg';
import SlugH6 from '../../assets/images/Slug Herritagae PICs/SlugH6.jpeg';
import SlugH7 from '../../assets/images/Slug Herritagae PICs/SlugH8.jpeg';
import SlugH8 from '../../assets/images/Slug Herritagae PICs/SlugH8.jpeg';
import SlugH9 from '../../assets/images/Slug Herritagae PICs/SlugH9.jpeg';
import SlugH10 from '../../assets/images/Slug Herritagae PICs/SlugH10.jpeg';
import SlugH11 from '../../assets/images/Slug Herritagae PICs/SlugH11.jpeg';
import SlugH12 from '../../assets/images/Slug Herritagae PICs/SlugH12.jpeg';
import SlugH13 from '../../assets/images/Slug Herritagae PICs/SlugH13.jpeg';
import SlugH14 from '../../assets/images/Slug Herritagae PICs/SlugH14.jpeg';
import SlugH15 from '../../assets/images/Slug Herritagae PICs/SlugH15.jpeg';
import SlugH16 from '../../assets/images/Slug Herritagae PICs/SlugH16.jpeg';
import SlugH17 from '../../assets/images/Slug Herritagae PICs/SlugH17.jpeg';

const galleryImages = [SlugH2, SlugH3, SlugH4, SlugH5, SlugH6, SlugH7, SlugH8, SlugH9, SlugH10, SlugH11, SlugH12, SlugH13, SlugH14, SlugH15, SlugH16, SlugH17];
---

<MainLayout title="Petrellen Court | Foxton Group">

  <!-- Hero - now using SlugH1 -->
  <div class="project-hero">
    <img src={heroImg.src} alt="Petrellen Court" class="hero-image" />
    <div class="hero-overlay">
      <div class="hero-text">
        <h1>Petrellen Court</h1>
        <p class="location">Rosudgeon, Cornwall, UK • 2020–Present</p>
      </div>
    </div>
  </div>

  <div class="project-content">
    <div class="description">
      <p>Foxton Group partnered with Selleck Nicholls Homes to rejuvenate this stunning Grade II listed development by restoring the historic features. The complete heritage restoration, sympathetic extensions and alterations across the property, with new build two bedroomed townhouse with garage. The build showcases exceptional craftsmanship and sympathetic restoration throughout.</p>
    </div>

    <!-- Gallery (starts from image 2) -->
    <div class="gallery">
      <h2>Project Gallery</h2>
      <div class="image-grid">
        {galleryImages.map((img, i) => (
          <div class="gallery-item" key={i}>
            <img 
              src={img.src} 
              alt={`Petrellen Court - ${i + 2}`} 
              loading="lazy"
            />
            <div class="caption">Image {i + 2}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Back button -->
    <div class="back-button">
      <a href="/projects" class="btn-secondary">← Back to Projects</a>
    </div>
  </div>

  <style>
    .project-hero {
      position: relative;
      height: 75vh;
      overflow: hidden;
    }
    .hero-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .hero-overlay {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      background: linear-gradient(transparent, rgba(0,0,0,0.65));
      padding: 3rem 2rem 2rem;
      color: white;
    }
    .hero-text h1 {
      font-size: clamp(2.8rem, 5vw, 4.2rem);
      margin-bottom: 0.5rem;
      font-weight: 300;
    }
    .location {
      font-size: 1.25rem;
      opacity: 0.9;
    }

    .project-content {
      max-width: 1380px;
      margin: 4rem auto;
      padding: 0 2rem;
    }
    .description {
      font-size: 1.2rem;
      line-height: 1.7;
      max-width: 800px;
      margin-bottom: 4rem;
      color: #333;
    }

    .gallery h2 {
      margin-bottom: 2rem;
      font-size: 2.25rem;
      color: #0A3D2F;
    }
    .image-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 1.5rem;
    }
    .gallery-item img {
      width: 100%;
      height: auto;
      border-radius: 0.75rem;
      box-shadow: 0 10px 25px rgba(0,0,0,0.1);
      transition: transform 0.3s ease;
    }
    .gallery-item:hover img {
      transform: scale(1.03);
    }
    .caption {
      margin-top: 0.75rem;
      text-align: center;
      font-size: 1rem;
      color: #555;
      font-weight: 500;
    }

    .back-button {
      margin-top: 4rem;
      text-align: center;
    }
    .btn-secondary {
      display: inline-block;
      padding: 1rem 2.5rem;
      background: #f5f5f5;
      color: #222;
      border-radius: 9999px;
      text-decoration: none;
      font-weight: 500;
    }
    .btn-secondary:hover {
      background: #222;
      color: white;
    }
  </style>
</MainLayout>