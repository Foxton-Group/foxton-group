---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import '/src/assets/fonts/raleway.css';
const { title = 'Foxton Group', showFooter = true } = Astro.props;
---

<!doctype html>
<head>
  <meta charset="UTF-8" />
  <!-- Enhanced viewport for Safari (Chrome ignores extra params) -->
  <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no, viewport-fit=cover" />
  <title>Foxton Group</title>

  <!-- Safari-only text-size fix (100% harmless in Chrome) -->
  <style>
    @supports (-webkit-appearance: none) {
      html {
        -webkit-text-size-adjust: 100% !important;
        text-size-adjust: 100% !important;
      }
    }
  </style>
</head>
<body class="flex flex-col min-h-screen bg-[#F5F4F0] w-full max-w-none mx-0 px-0">

  <Header />

<main class="flex-1 w-full max-w-none mx-0 px-0 max-w-full !px-0"></main>
    <slot />
  </main>

{showFooter && <Footer />}

</body>
</html>